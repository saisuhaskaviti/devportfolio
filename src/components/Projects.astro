---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-white">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                return (
                  <div class="group relative">
                    <Component
                      {...linkProps}
                      class={`block relative p-6 sm:p-8 md:p-10 bg-slate-800/40 rounded-2xl border border-slate-700/50 transition-all duration-300 ${
                        project.link
                          ? "hover:bg-slate-800/60 hover:shadow-xl hover:shadow-indigo-500/10 hover:border-slate-600 hover:-translate-y-1"
                          : ""
                      }`}
                    >
                      {project.link && (
                        <div class="absolute top-6 right-6 sm:top-8 sm:right-8 w-10 h-10 sm:w-12 sm:h-12 flex items-center justify-center bg-slate-700 rounded-full text-white transition-all duration-300 group-hover:bg-[var(--accent-color)]" style={`--accent-color: ${siteConfig.accentColor}`}>
                          <svg
                            class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <div class="space-y-5">
                        <div>
                          <span
                            class="text-sm font-mono font-bold"
                            style={{ color: siteConfig.accentColor }}
                          >
                            0{index + 1}
                          </span>
                          <h3 class="text-2xl sm:text-3xl font-bold text-white mt-2">
                            {project.name}
                          </h3>
                        </div>

                        <div
                          class={`text-base sm:text-lg text-slate-300 leading-relaxed ${project.link ? "pr-12 sm:pr-14" : ""}`}
                          set:html={project.description}
                        />

                        {project.skills && project.skills.length > 0 && (
                          <div class="flex flex-wrap gap-2 pt-4">
                            {project.skills.map((skill) => (
                              <span
                                class={`px-3 py-1.5 bg-slate-900/80 border border-slate-700/50 text-slate-200 rounded-full text-sm font-medium transition-all duration-300 ${
                                  project.link ? "group-hover:border-slate-500/50" : ""
                                }`}
                              >
                                {skill}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                    </Component>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
