---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section class="px-8 sm:px-12 md:px-16 lg:px-24 pb-12">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h3 class="text-2xl sm:text-3xl font-bold text-slate-200">
              Experience
            </h3>
          </div>

          <div class="lg:col-span-8">
            <div class="relative">
              {siteConfig.experience.map((exp, index) => (
                <div class="relative mb-8 last:mb-0">
                  {/* Timeline dot at top of card */}
                  <div
                    class="absolute left-[-16px] sm:left-[-24px] top-6 w-3 h-3 rounded-full z-20 transition-all duration-300 hidden sm:block"
                    style={`background-color: ${siteConfig.accentColor}`}
                  />

                  {/* Connecting line left of card */}
                  {index < siteConfig.experience.length - 1 && (
                    <div class="absolute left-[-11px] sm:left-[-19px] top-10 w-0.5 h-[calc(100%+16px)] bg-slate-700 z-10 hidden sm:block" />
                  )}

                  {/* Experience card */}
                  <div class="bg-slate-800/40 rounded-xl border border-slate-700/50 p-5 sm:p-6 md:p-8 hover:shadow-md transition-shadow duration-300">
                    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                      <div>
                        <h4 class="text-xl font-bold text-white">
                          {exp.title}
                        </h4>
                        <p
                          class="text-lg font-medium mt-1"
                          style={`color: ${siteConfig.accentColor}`}
                        >
                          {exp.company}
                        </p>
                      </div>
                      <span class="text-sm font-mono text-slate-400 mt-2 sm:mt-1 whitespace-nowrap bg-slate-900/50 px-3 py-1 rounded-full border border-slate-700/50">
                        {exp.dateRange}
                      </span>
                    </div>

                    <ul class="space-y-3 mt-4">
                      {exp.bullets.map((bullet) => (
                        <li class="flex items-start">
                          <span class="inline-block w-1.5 h-1.5 rounded-full bg-slate-500 mt-2.5 mr-3 flex-shrink-0" />
                          <span class="text-base text-slate-300 leading-relaxed">
                            {bullet}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
